---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  const products = [
    {
      id: 1,
      name: "Premium Horse Feed",
      price: 45.99,
      image:
        "https://images.unsplash.com/photo-1553284965-83fd3e82fa5a?w=800&h=600&fit=crop",
      category: "Nutrition",
      description:
        "High-quality feed for optimal horse health and performance. Specially formulated with essential vitamins, minerals, and nutrients to support your horse's overall well-being.",
      features: [
        "Complete nutritional balance",
        "Rich in vitamins and minerals",
        "Supports digestive health",
        "Promotes shiny coat",
      ],
      stock: 15,
    },
    {
      id: 2,
      name: "Riding Helmet Pro",
      price: 129.99,
      image:
        "https://images.unsplash.com/photo-1535082623926-b37a8d9f7f86?w=800&h=600&fit=crop",
      category: "Safety",
      description:
        "Certified protection for equestrian sports. Features advanced impact absorption technology and breathable ventilation system for maximum comfort.",
      features: [
        "ASTM/SEI certified",
        "Adjustable fit system",
        "Air ventilation",
        "Lightweight design",
      ],
      stock: 8,
    },
    {
      id: 3,
      name: "Leather Saddle",
      price: 899.99,
      image:
        "https://images.unsplash.com/photo-1595975342333-39e5c1c2448d?w=800&h=600&fit=crop",
      category: "Equipment",
      description:
        "Handcrafted premium leather saddle with traditional stitching. Made from the finest quality leather for durability and timeless elegance.",
      features: [
        "Premium full-grain leather",
        "Hand-stitched details",
        "Comfortable seat",
        "Durable tree construction",
      ],
      stock: 3,
    },
    {
      id: 4,
      name: "Horse Brush Set",
      price: 34.99,
      image:
        "https://images.unsplash.com/photo-1601758124510-52d02ddb7cbd?w=800&h=600&fit=crop",
      category: "Grooming",
      description:
        "Complete grooming kit for your horse. Includes all essential brushes for coat maintenance, from curry combs to finishing brushes.",
      features: [
        "7-piece grooming set",
        "Ergonomic handles",
        "Soft bristles",
        "Durable construction",
      ],
      stock: 25,
    },
    {
      id: 5,
      name: "Riding Boots Elite",
      price: 189.99,
      image:
        "https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=800&h=600&fit=crop",
      category: "Apparel",
      description:
        "Professional riding boots with ankle support and premium leather construction. Designed for both comfort and performance in the saddle.",
      features: [
        "Premium leather",
        "Ankle support",
        "Non-slip sole",
        "Side zipper closure",
      ],
      stock: 12,
    },
    {
      id: 6,
      name: "Stable Mat",
      price: 59.99,
      image:
        "https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?w=800&h=600&fit=crop",
      category: "Stable",
      description:
        "Anti-fatigue stable flooring solution. Provides comfort for horses and easy cleaning for owners.",
      features: [
        "Non-slip surface",
        "Easy to clean",
        "Shock absorbing",
        "Interlocking design",
      ],
      stock: 30,
    },
    {
      id: 7,
      name: "Horse Supplements",
      price: 28.99,
      image:
        "https://images.unsplash.com/photo-1589939705384-5185137a7f0f?w=800&h=600&fit=crop",
      category: "Nutrition",
      description:
        "Comprehensive vitamins and minerals supplement pack to support your horse's health and performance.",
      features: [
        "Complete vitamin complex",
        "Essential minerals",
        "Supports immunity",
        "Easy to administer",
      ],
      stock: 20,
    },
    {
      id: 8,
      name: "Equestrian Gloves",
      price: 24.99,
      image:
        "https://images.unsplash.com/photo-1588850561407-ed78c282e89b?w=800&h=600&fit=crop",
      category: "Apparel",
      description:
        "Breathable riding gloves with enhanced grip and touch screen compatible fingertips.",
      features: [
        "Breathable fabric",
        "Enhanced grip",
        "Touch screen compatible",
        "Adjustable closure",
      ],
      stock: 18,
    },
  ];

  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout title={`${product.name} - Equestrian Shop`}>
  <main class="product-detail">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="separator">/</span>
      <a href="/#products">Products</a>
      <span class="separator">/</span>
      <span class="current">{product.name}</span>
    </div>

    <div class="product-container">
      <div class="product-image-section">
        <div class="image-wrapper">
          <img src={product.image} alt={product.name} class="product-image" />
          <span class="category-badge">{product.category}</span>
        </div>
      </div>

      <div class="product-info-section">
        <h1 class="product-title">{product.name}</h1>

        <div class="price-stock">
          <span class="product-price">${product.price.toFixed(2)}</span>
          <span
            class={`stock-badge ${product.stock > 5 ? "in-stock" : "low-stock"}`}
          >
            {product.stock > 5 ? "In Stock" : `Only ${product.stock} left`}
          </span>
        </div>

        <p class="product-description">{product.description}</p>

        <div class="quantity-selector">
          <label for="quantity">Quantity</label>
          <div class="quantity-controls">
            <button class="qty-btn" onclick="decreaseQty()">-</button>
            <input
              type="number"
              id="quantity"
              value="1"
              min="1"
              max={product.stock}
            />
            <button class="qty-btn" onclick="increaseQty()">+</button>
          </div>
        </div>

        <div class="action-buttons">
          <button class="add-to-cart-btn">
            <span class="material-icons">shopping_cart</span>
            Add to Cart
          </button>
          <button class="wishlist-btn">
            <span class="material-icons">favorite_border</span>
          </button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .product-detail {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--accent-green);
  }

  .breadcrumb .separator {
    color: var(--text-secondary);
  }

  .breadcrumb .current {
    color: var(--text-primary);
    font-weight: 500;
  }

  .product-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .image-wrapper {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: var(--card-bg);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .product-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .category-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--accent-light-green);
    color: var(--accent-green);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .price-stock {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .product-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .stock-badge {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 20px;
  }

  .stock-badge.in-stock {
    background: var(--accent-light-green);
    color: var(--accent-green);
  }

  .stock-badge.low-stock {
    background: #fef3c7;
    color: #d97706;
  }

  .product-description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 32px 0;
  }

  .check-icon {
    color: var(--accent-green);
    font-weight: 700;
  }

  .quantity-selector {
    margin-bottom: 24px;
  }

  .quantity-selector label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .quantity-controls {
    display: flex;
    align-items: center;
    gap: 0;
    width: fit-content;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }

  .qty-btn {
    width: 40px;
    height: 40px;
    border: none;
    background: var(--bg-color);
    color: var(--text-primary);
    font-size: 1.25rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .qty-btn:hover {
    background: var(--accent-light-green);
  }

  .quantity-controls input {
    width: 60px;
    height: 40px;
    border: none;
    border-left: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    text-align: center;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    -moz-appearance: textfield;
  }

  .quantity-controls input::-webkit-outer-spin-button,
  .quantity-controls input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .action-buttons {
    display: flex;
    gap: 12px;
  }

  .add-to-cart-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--accent-green);
    color: white;
    border: none;
    padding: 16px 32px;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .add-to-cart-btn:hover {
    background: var(--brown-dark);
    transform: translateY(-2px);
  }

  .add-to-cart-btn .material-icons {
    font-size: 20px;
  }

  .wishlist-btn {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .wishlist-btn:hover {
    border-color: var(--accent-green);
    background: var(--accent-light-green);
  }

  .wishlist-btn .material-icons {
    color: var(--text-secondary);
    font-size: 24px;
  }

  @media (max-width: 768px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-title {
      font-size: 1.5rem;
    }

    .product-price {
      font-size: 1.5rem;
    }
  }
</style>
