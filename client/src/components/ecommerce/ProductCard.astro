---
import type { Product } from "../../interfaces/product.interface";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="product-card" data-product={JSON.stringify(product)}>
  <a href={`/product/${product.id}`} class="product-link">
    <div class="product-image-container">
      <img
        src={product.image}
        alt={product.name}
        class="product-image"
        loading="lazy"
      />
    </div>
    <div class="product-info">
      <h3 class="product-name">{product.name}</h3>
      <p class="product-description">{product.description}</p>
    </div>
  </a>
  <div class="product-footer">
    <span class="product-price">${product.price}</span>
    <button class="add-to-cart-btn">
      <span class="material-icons">shopping_cart</span>
      <span class="btn-text">Add</span>
    </button>
  </div>
</article>

<style>
  .product-card {
    background: var(--card-bg);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
  }

  .product-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .product-image-container {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-category {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--accent-light-green);
    color: var(--accent-green);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 6px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-info {
    padding: 20px;
  }

  .product-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 8px 0;
  }

  .product-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px 20px;
  }

  .product-price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-green);
  }

  .add-to-cart-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-green);
    color: white;
    border: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .add-to-cart-btn:hover {
    background: var(--brown-dark);
  }

  .add-to-cart-btn .material-icons {
    font-size: 18px;
  }

  .add-to-cart-btn.added {
    background: #059669;
  }

  .add-to-cart-btn.added .btn-text {
    display: none;
  }

  .add-to-cart-btn.added::after {
    content: "Added";
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 24px;
    }

    .hero-title {
      font-size: 2rem;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }
  }
</style>

<script>
  import { useBoundStore } from "../../context";

  function attachCartHandlers() {
    document.querySelectorAll(".add-to-cart-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        const card = (e.target as HTMLElement).closest(".product-card");
        const productData = card?.getAttribute("data-product");

        if (productData) {
          const product = JSON.parse(productData);
          useBoundStore.getState().addItem(product, 1);

          // Visual feedback
          const button = (e.target as HTMLElement).closest(
            ".add-to-cart-btn"
          ) as HTMLElement;
          button.classList.add("added");

          setTimeout(() => {
            button.classList.remove("added");
          }, 1500);

          // Dispatch event for cart button update
          window.dispatchEvent(new CustomEvent("cart-updated"));
        }
      });
    });
  }

  // Run on initial load
  attachCartHandlers();

  // Run on each navigation with ClientRouter
  document.addEventListener("astro:page-load", attachCartHandlers);
</script>
