---
import ProductsGrid from "./ProductsGrid.astro";

import { getProducts } from "../../services/product.service";
import type { Products } from "../../interfaces/product.interface";

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") || "1");

const { data: productsResponse, error } = await getProducts(page);

const products = productsResponse?.data || [];
const totalPages = productsResponse?.totalPages || 1;

if (error) {
  console.error("Error fetching products:", error);
}
---

<section id="products" class="products-section">
  <div class="section-header">
    <h2 class="section-title">Featured Products</h2>
    <p class="section-subtitle">Explore our selection of quality products</p>
  </div>

  <ProductsGrid products={products} page={page} totalPages={totalPages} />
</section>

<style>
  .products-section {
    padding-bottom: 80px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 12px 0;
  }

  .section-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
  }
</style>
