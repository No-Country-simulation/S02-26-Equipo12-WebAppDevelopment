---

---

<div class="panel-left">
    <div class="live-preview-badge">
        <span class="pulse-dot"></span>
        Live Preview
    </div>

    <div class="horse-illustration">
        <img
            class="horse-img-placeholder"
            data-alt="Abstract minimal line art horse profile"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCfHcYH90oW-qxUUhWYvUpLps3PGSGkGQsG_mAdp7S-dId2r-lgn6icXq0Za97QYCjN46B46QH-UiWTDMi1SbiYF-ARL_fHuN6CcJaGZXEJFMeC7tfFZhDF6SWpUHb_dpstoB9ge3dOdRlPVX0AJIZ7vghouOLy34dvk9L9S0RdepvgiahEf5dp5mDkRsGgQpyIbtEw2vdyGDulIuOKM0MXVHA9HThJ0oAf8XdunGuK8kLAaG3N2FRsBKUdc-mT_DSaT9nLSIyrShfq"
            aria-label="Line art illustration of a horse for measurement reference"
        />

        <svg class="svg-overlay" viewBox="0 0 400 300">
            <path
                d="M80,180 Q90,120 120,100 T180,90 T240,100 T300,120 L300,220 M120,100 L110,60 Q120,40 160,50 L180,90"
                fill="none"
                stroke="#9ca3af"
                stroke-width="2"></path>

            <g style="opacity: 1;">
                <line
                    class="measurement-line"
                    stroke="#17cf54"
                    stroke-dasharray="4"
                    stroke-width="2"
                    x1="180"
                    x2="300"
                    y1="90"
                    y2="120"></line>
                <circle fill="#17cf54" cx="180" cy="90" r="4"></circle>
                <circle fill="#17cf54" cx="300" cy="120" r="4"></circle>
                <text
                    fill="#17cf54"
                    font-size="12px"
                    font-weight="bold"
                    font-family="Manrope"
                    text-anchor="middle"
                    x="240"
                    y="80">A: Back Length</text
                >
            </g>

            <g style="opacity: 0.4;">
                <line
                    stroke="#9ca3af"
                    stroke-dasharray="4"
                    stroke-width="2"
                    x1="180"
                    x2="180"
                    y1="90"
                    y2="250"></line>
                <text
                    fill="#9ca3af"
                    font-size="12px"
                    font-weight="bold"
                    font-family="Manrope"
                    text-anchor="middle"
                    x="160"
                    y="170">B: Height</text
                >
            </g>

            <g style="opacity: 0.4;">
                <ellipse
                    stroke="#9ca3af"
                    cx="200"
                    cy="140"
                    fill="none"
                    rx="15"
                    ry="30"
                    stroke-dasharray="4"
                    stroke-width="2"
                    transform="rotate(-10 200 140)"></ellipse>
                <text
                    fill="#9ca3af"
                    font-size="12px"
                    font-weight="bold"
                    font-family="Manrope"
                    text-anchor="middle"
                    x="230"
                    y="160">C: Girth</text
                >
            </g>
        </svg>
    </div>

    <div class="pro-tip-box">
        <div class="pro-tip-icon">
            <span class="material-icons">tips_and_updates</span>
        </div>
        <div class="pro-tip-content">
            <h4>Pro Tip</h4>
            <p>
                Ensure your horse is standing squarely on level ground. Use a
                soft measuring tape for the girth circumference.
            </p>
        </div>
    </div>
</div>
