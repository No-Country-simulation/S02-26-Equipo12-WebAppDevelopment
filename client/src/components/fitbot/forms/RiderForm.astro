---
import "./index.css";

import Form from "../../ui/Form/Form.astro";
import FormSection from "../../ui/Form/FormSection.astro";
import Field from "../../ui/Form/Field.astro";
import Input from "../../ui/Form/Input.astro";
import Button from "../../ui/Button.astro";
---

<div class="form-panel-container">
    <Form id="rider-measurements-form" method="POST" action="#">
        <div>
            <FormSection class="section-grid">
                <div slot="form-header">
                    <header>
                        <h2>Basic Info</h2>
                    </header>
                </div>

                <Field label="Height" name="riderHeight">
                    <Input
                        type="number"
                        suffix="cm"
                        name="riderHeight"
                        id="riderHeight"
                        placeholder="0.0"
                    />
                </Field>

                <Field label="Weight" name="riderWeight">
                    <Input
                        type="number"
                        suffix="kg"
                        name="riderWeight"
                        id="riderWeight"
                        placeholder="0.0"
                    />
                </Field>

                <Field label="Gender Preference" name="riderGenderFit">
                    <div class="select-wrapper">
                        <select name="riderGenderFit" class="select-field">
                            <option value="male" class="options"> Male </option>
                            <option value="female" class="options">
                                Female
                            </option>
                        </select>
                    </div>
                </Field>
            </FormSection>

            <FormSection class="section-grid-vertical">
                <div slot="form-header">
                    <header>
                        <h2>Head & Torso</h2>
                    </header>

                    <span class="how-to">
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="10"></circle><path
                                d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"
                            ></path><line x1="12" y1="17" x2="12.01" y2="17"
                            ></line></svg
                        >
                        How to measure
                    </span>
                </div>

                <Field label="Head Circumference" name="riderHeadCircumference">
                    <Input
                        type="number"
                        suffix="cm"
                        name="riderHeadCircumference"
                        id="riderHeadCircumference"
                        placeholder="0.0"
                    />
                </Field>
            </FormSection>

            <FormSection class="section-grid">
                <div slot="form-header">
                    <header>
                        <h2>Legs & Feet</h2>
                    </header>
                    <!-- <p>Accurate calf and height measurements are essential for custom boot fitting</p> -->
                </div>

                <Field label="Calf Circumference" name="riderCalfCircumference">
                    <Input
                        type="number"
                        suffix="cm"
                        name="riderCalfCircumference"
                        id="riderCalfCircumference"
                        placeholder="0.0"
                    />
                </Field>

                <Field label="Foot Length" name="riderFootLength">
                    <Input
                        type="number"
                        suffix="cm"
                        name="riderFootLength"
                        id="riderFootLength"
                        placeholder="0.0"
                    />
                </Field>
            </FormSection>

            <div class="button-container">
                <Button type="submit" variant="signin" size="sm">
                    Enviar
                </Button>
                <Button type="reset" variant="primary"> Reset </Button>
            </div>
        </div>
    </Form>
</div>

<style>
    .select-wrapper {
        position: relative;
        display: flex;
        align-items: center;

        background-color: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: 8px;

        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            background-color 0.2s;

        overflow: hidden;
    }

    .select-field {
        flex: 1;
        width: 100%;

        border: 0;
        background: transparent;

        padding: 14px 16px;
        font-size: 1rem;
        color: var(--text-main);
        font-family: inherit;
        outline: none;
    }

    .options {
        padding-right: 16px;
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        pointer-events: none;
        user-select: none;
    }

    .input-field:focus {
        border-color: var(--primary);
        /* box-shadow: 0 0 0 3px rgba(23, 207, 84, 0.2); */
    }

    .how-to {
        float: right;
        font-size: 0.8rem;
        color: var(--text-gray);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;

        &:hover {
            color: var(--primary-green-hover);
        }
    }

    .button-container {
        display: flex;
        justify-content: space-around;
    }

    .form-panel-container {
        max-width: 100%;
        display: flex;
        justify-content: center;
        overflow-y: auto;
        padding: 40px 60px;
        padding-bottom: 120px;
    }
</style>

<script is:inline type="module">

    import { mountRiderMeasurementsForm } from "./src/components/fitbot/scripts/riderMeasurements";
    mountRiderMeasurementsForm("rider-measurements-form");

</script>
