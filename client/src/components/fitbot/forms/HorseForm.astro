---
import Form from "../../ui/Form/Form.astro";
import FormSection from "../../ui/Form/FormSection.astro";
import Field from "../../ui/Form/Field.astro";
import Input from "../../ui/Form/Input.astro";

import Button from "../../ui/Button.astro";

import "./index.css";
---

<div class="form-panel-container">
    <Form id="horse-measurements-form" method="POST" action="#">
        <div>
            <FormSection class="section-grid">
                <div slot="form-header">
                    <header>
                        <h2>Horse Measurements</h2>
                        <p>Enter the measurements in centimeters.</p>
                    </header>
                </div>

                <Field label="Back Length" name="horseBackLength">
                    <Input
                        type="number"
                        suffix="cm"
                        name="horseBackLength"
                        id="horseBackLength"
                        placeholder="0.0"
                    />
                </Field>

                <Field label="Girth Circumference" name="horseGirthCircumference">
                    <Input
                        type="number"
                        suffix="cm"
                        name="horseGirthCircumference"
                        id="horseGirthCircumference"
                        placeholder="0.0"
                    />
                </Field>
            </FormSection>

            <div class="button-container">
                <Button type="submit" variant="signin" size="sm">
                    Enviar
                </Button>
                <Button type="reset" variant="primary"> Reset </Button>
            </div>
        </div>
    </Form>
</div>

<style>
    header {
        /* background-color: aqua; */
        display: flex;
        flex-direction: column;
    }

    p {
        margin-top: 0.5rem;
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    h2 {
        font-size: 2rem;
        text-align: center;
    }

    .select-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background-color: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            background-color 0.2s;
        overflow: hidden;
    }

    .select-field {
        flex: 1;
        width: 100%;
        border: 0;
        background: transparent;
        padding: 14px 16px;
        font-size: 1rem;
        color: var(--text-main);
        font-family: inherit;
        outline: none;
    }

    .options {
        padding-right: 16px;
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        pointer-events: none;
        user-select: none;
    }

    .input-field:focus {
        border-color: var(--primary);
    }

    .button-container {
        display: flex;
        justify-content: space-around;
        margin-top: 2rem;
    }

    .form-panel-container {
        max-width: 100%;
        height: 700px;
        display: flex;
        justify-content: center;
        overflow-y: auto;
        padding: 40px 60px;
        padding-bottom: 120px;
    }
</style>


<script is:inline type="module">

    import { mountHorseMeasurementsForm } from "./src/components/fitbot/scripts/horseMeasurements";

    mountHorseMeasurementsForm("horse-measurements-form");

</script>