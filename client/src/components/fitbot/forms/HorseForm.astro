---
import Form from "../../ui/Form/Form.astro";
import FormSection from "../../ui/Form/FormSection.astro";
import Field from "../../ui/Form/Field.astro";
import Input from "../../ui/Form/Input.astro";

import Button from "../../ui/Button.astro";
---

<div class="form-panel-container">
    <Form id="horse-measurements-form" method="POST" action="#">
        <div>
            <FormSection class="section-grid">
                <div slot="form-header">
                    <header>
                        <h2>Horse Measurements</h2>
                        <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 5px;">
                            Enter the measurements in centimeters.
                        </p>
                    </header>
                </div>

                <Field label="Back Length" name="backLength">
                    <Input
                        type="number"
                        suffix="cm"
                        name="backLength"
                        id="backLength"
                        placeholder="0.0"
                    />
                </Field>

                <Field label="Girth Circumference" name="girthCircumference">
                    <Input
                        type="number"
                        suffix="cm"
                        name="girthCircumference"
                        id="girthCircumference"
                        placeholder="0.0"
                    />
                </Field>

            </FormSection>

            <div class="button-container">
                <Button type="submit" variant="signin" size="sm">
                    Enviar
                </Button>
                <Button type="reset" variant="primary"> Reset </Button>
            </div>
        </div>
    </Form>
</div>

<style>
    /* Estilos conservados tal cual */
    .select-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background-color: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        transition: border-color 0.2s, box-shadow 0.2s, background-color 0.2s;
        overflow: hidden;
    }

    .select-field {
        flex: 1;
        width: 100%;
        border: 0;
        background: transparent;
        padding: 14px 16px;
        font-size: 1rem;
        color: var(--text-main);
        font-family: inherit;
        outline: none;
    }

    .options {
        padding-right: 16px;
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        pointer-events: none;
        user-select: none;
    }

    .input-field:focus {
        border-color: var(--primary);
    }

    .how-to {
        float: right;
        font-size: 0.8rem;
        color: var(--text-gray);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .how-to:hover {
        color: var(--primary-green-hover);
    }

    .button-container {
        display: flex;
        justify-content: space-around;
        margin-top: 2rem; /* Añadido un poco de espacio arriba de los botones */
    }

    .form-panel-container {
        max-width: 100%;
        display: flex;
        justify-content: center;
        overflow-y: auto;
        padding: 40px 60px;
        padding-bottom: 120px;
    }
</style>