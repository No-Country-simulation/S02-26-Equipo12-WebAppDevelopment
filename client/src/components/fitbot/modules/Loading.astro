<main class="app-main">
    <div class="radar-wrapper">
        <div class="radar-bg"></div>
        <div class="radar-ring-1"></div>
        <div class="radar-ring-2"></div>

        <svg
            class="radar-svg"
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <circle cx="15" cy="45" r="2" fill="#17cf54" opacity="0.6"></circle>
            <circle cx="85" cy="20" r="2.5" fill="#17cf54"></circle>
            <circle cx="25" cy="25" r="1.5" fill="#17cf54" opacity="0.4"
            ></circle>

            <path
                d="M 20 60 C 35 30, 45 20, 55 25 C 75 35, 45 45, 65 75"
                stroke="#17cf54"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-dasharray="150"
                stroke-dashoffset="150"
                style="animation: draw 2s ease-out forwards;"></path>

            <circle
                cx="65"
                cy="75"
                r="3"
                stroke="#17cf54"
                stroke-width="2"
                fill="#ffffff"></circle>
        </svg>
    </div>

    <h1 class="title">Fitbot is analyzing your<br />measurements...</h1>
    <p class="subtitle">Scanning dimension data points...</p>

    <div class="progress-container">
        <div class="progress-labels">
            <span>Processing</span>
            <span>72%</span>
        </div>
        <div class="progress-track">
            <div class="progress-fill"></div>
        </div>
    </div>

    <div class="steps">
        <div class="step current">
            <div class="step-dot"></div>
            <span class="step-label">Scanning</span>
        </div>
        <div class="step done">
            <div class="step-dot"></div>
            <span class="step-label">Matching</span>
        </div>
        <div class="step">
            <div class="step-dot"></div>
            <span class="step-label">Suggesting</span>
        </div>
    </div>
</main>

