---
import Field from "../ui/Form/Field.astro";
import Input from "../ui/Form/Input.astro";
import Button from "../ui/Button.astro";
---

<style>
    body {
        /* Background Blooms/Gradients */
        background-image:
            radial-gradient(
                circle at 15% 85%,
                rgba(16, 185, 129, 0.08) 0%,
                transparent 25%
            ),
            radial-gradient(
                circle at 85% 15%,
                rgba(16, 185, 129, 0.08) 0%,
                transparent 25%
            );
    }

    .main-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem;
    }

    /* --- Card Container --- */
    .login-card {
        background: var(--card-bg);
        width: 100%;
        max-width: 440px;
        padding: 48px 40px;
        border-radius: 12px;
        box-shadow:
            0 4px 6px -1px rgba(0, 0, 0, 0.05),
            0 2px 4px -1px rgba(0, 0, 0, 0.03);
        border: 1px solid rgba(0, 0, 0, 0.02);
        text-align: center;
        margin-bottom: 32px;
    }

    /* --- Header Section --- */
    .logo-section {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 24px;
    }

    .logo-icon {
        width: 32px;
        height: 32px;
        background-color: var(--primary-green);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .logo-text {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    h1 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-dark);
    }

    .subtitle {
        font-size: 0.95rem;
        color: var(--text-secondary);
        margin-bottom: 32px;
        line-height: 1.5;
    }

    /* --- Form Elements --- */
    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-dark);
    }

    .forgot-link {
        font-size: 0.875rem;
        color: var(--primary-green);
        text-decoration: none;
        font-weight: 500;
    }

    .forgot-link:hover {
        text-decoration: underline;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    input {
        width: 100%;
        padding: 12px 16px;
        font-size: 1rem;
        border: 1px solid var(--border-light);
        border-radius: 6px;
        outline: none;
        transition: all 0.2s ease;
        color: var(--text-dark);
    }

    input::placeholder {
        color: #9ca3af;
    }

    input:focus {
        border-color: var(--primary-green);
        box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .eye-icon {
        position: absolute;
        right: 14px;
        color: #9ca3af;
        cursor: pointer;
        display: flex;
        align-items: center;
    }

    /* --- Buttons --- */
    .btn-primary {
        width: 100%;
        background-color: var(--primary-green);
        color: white;
        border: none;
        padding: 12px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 8px;
        transition: background-color 0.2s;
    }

    .btn-primary:hover {
        background-color: var(--primary-green-hover);
    }

    /* --- Divider --- */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 28px 0;
        color: #9ca3af;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .divider::before,
    .divider::after {
        content: "";
        flex: 1;
        border-bottom: 1px solid var(--border-light);
    }

    .divider span {
        padding: 0 12px;
        text-transform: uppercase;
    }

    /* --- Social Buttons --- */
    .social-buttons {
        display: flex;
        gap: 16px;
        margin-bottom: 32px;
    }

    .btn-social {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background-color: white;
        border: 1px solid var(--border-light);
        padding: 10px;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--text-dark);
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-social:hover {
        background-color: #f9fafb;
        border-color: #d1d5db;
    }

    .signup-text {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .signup-link {
        color: var(--primary-green);
        text-decoration: none;
        font-weight: 600;
        margin-left: 4px;
    }

    /* --- Footer Badge --- */
    .footer-secure {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #9ca3af;
        font-size: 0.85rem;
    }
</style>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EquiFit - Welcome Back</title>
</head>

<main class="main-container">
    <div class="login-card">
        <div class="logo-section">
            <div class="logo-icon">
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
                    ></path></svg
                >
            </div>
            <span class="logo-text">EquiFit</span>
        </div>

        <h1>Welcome Back</h1>
        <p class="subtitle">Log in to manage your gear.</p>

        <form action="#">
            <!-- <div class="form-group">
                <div class="label-row">
                    <label for="email">Email Address</label>
                </div>
                <input type="email" id="email" placeholder="Enter your email" />
            </div> -->
            <Field label="Email Address" name="email">
                <Input type="email" id="email" placeholder="Enter your email" />
            </Field>
            <div class="form-group">
                <div class="label-row">
                    <label for="password">Password</label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>
                <div class="input-wrapper">
                    <input
                        type="password"
                        id="password"
                        placeholder="Enter your password"
                    />
                    <div class="eye-icon">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                            ></path><circle cx="12" cy="12" r="3"></circle></svg
                        >
                    </div>
                </div>
            </div>
            <p
                id="error-msg"
                style="display:none; color: #ef4444; font-size: 0.875rem; margin-bottom: 8px; text-align: left;"
            >
            </p>

            <button type="submit" class="btn-primary">Sign In</button>
            <!-- <Button type="submit" size="md">Sign In</Button> -->
        </form>

        <div class="divider">
            <span>Or continue with</span>
        </div>

        <div class="social-buttons">
            <button class="btn-social">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                        fill="#4285F4"></path><path
                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                        fill="#34A853"></path><path
                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                        fill="#FBBC05"></path><path
                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                        fill="#EA4335"></path></svg
                >
                Google
            </button>
            <button class="btn-social">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                        d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.74 1.18 0 2.45-1.02 3.8-1.02.66 0 2.7.27 3.5 1.54-3.07 1.63-2.52 5.76.5 7.06-.61 1.77-1.47 3.25-2.88 4.65zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.54 4.38-3.74 4.25z"
                    ></path></svg
                >
                Apple
            </button>
        </div>

        <div class="signup-text">
            Don't have an account? <a href="#" class="signup-link">Sign up</a>
        </div>
    </div>

    <div class="footer-secure">
        <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
        >
        <span>Secure equestrian management platform</span>
    </div>
</main>
<script>
    import { loginUser } from "../../services/auth.services";
    import { toast } from "sonner";
    
    const form = document.querySelector("form");
    const emailInput = document.querySelector("#email") as HTMLInputElement;
    const passwordInput = document.querySelector(
        "#password",
    ) as HTMLInputElement;
    const submitBtn = document.querySelector(
        'button[type="submit"]',
    ) as HTMLButtonElement;
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = "Signing in ...";

        try {
            const data = await loginUser(emailInput.value, passwordInput.value);
            localStorage.setItem("token", data.result.token);
            window.location.href = "/Fitbot";
        } catch (err:any) {
            const msg = err.response?.data?.message || "Error signing in. Please try again.";
            const errorMsg = document.querySelector("#error-msg") as HTMLParagraphElement;
            errorMsg.textContent = msg;
            errorMsg.style.display = "block";
            toast.error(msg);
            submitBtn.disabled = false;
            submitBtn.textContent = "Sign In";
        }
    });
</script>
