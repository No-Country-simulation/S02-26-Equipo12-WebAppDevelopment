---
import Card from "../ui/Card.astro";
import Form from "../ui/Form/Form.astro";
import FormSection from "../ui/Form/FormSection.astro";
import Field from "../ui/Form/Field.astro";
import Input from "../ui/Form/Input.astro";
import Button from "../ui/Button.astro";
import Eye from "../ui/Icons/eye.svg";
import LogoFitbot from "../ui/icons/fitbot-logo.svg";
import GoogleLogo from "../ui/icons/google.svg";
import AppleLogo from "../ui/icons/apple.svg";
import ShieldSecureLogo from "../ui/icons/shield-secure.svg";
---

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FitBot - Welcome Back</title>
</head>

<main class="main-container">
    <Card>
        <div slot="header">
            <div class="logo-section">
                <div class="logo-icon">
                    <LogoFitbot class="icon" />
                </div>

                <p class="logo-text">EquiFit</p>
                <!-- <span class="logo-text">EquiFit</span> -->
            </div>

            <h1>Welcome Back</h1>
            <p class="subtitle">Log in to manage your gear.</p>
        </div>

        <div slot="content">
            <Form method="POST">
                <div class="form-group">
                    <FormSection class="section-grid-vertical">
                        <Field label="Email Address" name="email" required>
                            <Input
                                id="email"
                                name="email"
                                type="email"
                                placeholder="Enter your Email"
                            />
                        </Field>

                        <Field label="Password" name="password" required>
                            <div class="eye-icon">
                                <Eye />
                            </div>
                            <Input
                                id="password"
                                name="password"
                                type="password"
                                placeholder="Enter your Password"
                            />

                            <a href="#" class="forgot-link">Forgot password?</a>
                        </Field>
                    </FormSection>
                </div>

                <Button size="lg" type="submit" variant="signin">
                    Sign In
                </Button>
            </Form>

            <div class="divider">
                <span>Or continue with</span>
            </div>

            <div class="social-buttons">
                <button class="btn-social">
                    <GoogleLogo />
                    Google
                </button>
                <button class="btn-social">
                    <AppleLogo />
                    Apple
                </button>
            </div>

            <div class="signup-text">
                Don't have an account?
                <a href="#" class="signup-link"> Sign up </a>
            </div>
        </div>

        <div class="footer-secure">
            <ShieldSecureLogo />

            <span>Secure equestrian management platform</span>
        </div>
    </Card>

    <div class="footer-secure">
        <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
        >
        <span>Secure equestrian management platform</span>
    </div>
</main>

<style>
    body {
        /* Background Blooms/Gradients */
        background-image:
            radial-gradient(
                circle at 15% 85%,
                rgba(16, 185, 129, 0.08) 0%,
                transparent 25%
            ),
            radial-gradient(
                circle at 85% 15%,
                rgba(16, 185, 129, 0.08) 0%,
                transparent 25%
            );
    }

    .main-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
    }

    /* --- Header Section --- */
    .logo-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;

        p {
            margin-top: -15px;
        }
    }

    .icon {
        width: auto;
        height: auto;
    }

    .logo-icon {
        width: 80px;
        height: 80px;
        /* background-color: var(--primary-green); */
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .logo-text {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    h1 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-dark);
    }

    .subtitle {
        font-size: 0.95rem;

        color: var(--text-secondary);
        margin-bottom: 32px;
        line-height: 1.5;
    }

    /* --- Form Elements --- */

    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

    .forgot-link {
        font-size: 0.875rem;
        color: var(--primary-green);
        text-decoration: none;
        font-weight: 500;
    }

    .forgot-link:hover {
        text-decoration: underline;
    }

    .eye-icon {
        position: absolute;
        right: 14px;
        top: 38px;
        color: #9ca3af;
        cursor: pointer;
        display: flex;
        align-items: center;
        z-index: 1;
    }

    /* --- Divider --- */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 28px 0;
        color: #9ca3af;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .divider::before,
    .divider::after {
        content: "";
        flex: 1;
        border-bottom: 1px solid var(--border-light);
    }

    .divider span {
        padding: 0 12px;
        text-transform: uppercase;
    }

    /* --- Social Buttons --- */
    .social-buttons {
        display: flex;
        gap: 16px;
        margin-bottom: 32px;
    }

    .btn-social {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background-color: white;
        border: 1px solid var(--border-light);
        padding: 10px;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--text-dark);
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-social:hover {
        background-color: #f9fafb;
        border-color: #d1d5db;
    }

    .signup-text {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .signup-link {
        color: var(--primary-green);
        text-decoration: none;
        font-weight: 600;
        margin-left: 4px;
    }

    /* --- Footer Badge --- */
    .footer-secure {
        display: flex;
        align-items: center;
        margin-top: 40px;
        gap: 8px;
        color: #9ca3af;
        font-size: 0.85rem;
    }
</style>
