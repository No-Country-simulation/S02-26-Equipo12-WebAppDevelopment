---
import "../styles/globals.css";
import "../styles/tokens.css";
import FitbotLogo from "../components/ui/icons/fitbot-logo.svg";

const { title = "EquiFit by FitBot" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{title}</title>

     	<link rel="icon" href="/logo.png" type="image/png" />

        <link
            href="https://fonts.googleapis.com/icon?family=Material+Icons"
            rel="stylesheet"
        />

        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=shopping_bag"
        />
    </head>

    <body>
        <slot />
    </body>
</html>

<style>


    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
